<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ILMANA Backend Status</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f4fbf7;
        --card: #ffffff;
        --ink: #123127;
        --muted: #5d7469;
        --line: #d6e6dc;
        --primary: #0f6a41;
        --primary-soft: #e6f4ed;
        --danger-soft: #fdecec;
        --danger: #b42318;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: linear-gradient(180deg, #eef8f2 0%, var(--bg) 100%);
        color: var(--ink);
      }
      .wrap { max-width: 1100px; margin: 0 auto; padding: 40px 20px 72px; }
      .hero, .card {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 20px;
        box-shadow: 0 18px 50px rgba(15, 106, 65, 0.08);
      }
      .hero { padding: 32px; }
      .eyebrow {
        display: inline-flex;
        padding: 8px 12px;
        border-radius: 999px;
        background: <%= dbHealthy ? "var(--primary-soft)" : "var(--danger-soft)" %>;
        color: <%= dbHealthy ? "var(--primary)" : "var(--danger)" %>;
        font-weight: 700;
        font-size: 13px;
      }
      h1 { margin: 16px 0 12px; font-size: clamp(32px, 4vw, 48px); line-height: 1.05; }
      p { margin: 0; color: var(--muted); line-height: 1.7; }
      .grid { display: grid; gap: 18px; margin-top: 20px; grid-template-columns: repeat(4, minmax(0, 1fr)); }
      .card { padding: 22px; }
      .stat-label { font-size: 13px; color: var(--muted); text-transform: uppercase; font-weight: 700; letter-spacing: 0.08em; }
      .stat-value { margin-top: 10px; font-size: 28px; font-weight: 800; }
      .stack { margin-top: 28px; display: grid; gap: 18px; grid-template-columns: 1.3fr 0.7fr; }
      .list { display: grid; gap: 12px; margin-top: 18px; }
      .list-item {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        padding: 14px 16px;
        border: 1px solid var(--line);
        border-radius: 14px;
        background: #fbfefd;
      }
      .badge {
        display: inline-flex;
        padding: 6px 10px;
        border-radius: 999px;
        background: var(--primary-soft);
        color: var(--primary);
        font-weight: 700;
        font-size: 12px;
      }
      a {
        color: var(--primary);
        text-decoration: none;
        font-weight: 700;
      }
      .actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 24px; }
      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 46px;
        padding: 0 18px;
        border-radius: 12px;
        border: 1px solid var(--line);
        background: #fff;
      }
      .button.primary {
        background: var(--primary);
        border-color: var(--primary);
        color: #fff;
      }
      @media (max-width: 900px) {
        .grid, .stack { grid-template-columns: 1fr 1fr; }
      }
      @media (max-width: 640px) {
        .wrap { padding: 24px 16px 48px; }
        .hero, .card { border-radius: 16px; }
        .grid, .stack { grid-template-columns: 1fr; }
        .list-item { flex-direction: column; }
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <section class="hero">
        <span class="eyebrow"><%= dbHealthy ? "Backend aktif" : "Backend perlu perhatian" %></span>
        <h1>ILMANA Backend API</h1>
        <p>
          Halaman ini menandakan service Express berjalan, route API terpasang, dan status koneksi database
          bisa dipantau tanpa membuka log server.
        </p>
        <div class="actions">
          <a class="button primary" href="/docs">Buka dokumentasi API</a>
          <a class="button" href="/api/health">Health JSON</a>
        </div>
      </section>

      <section class="grid">
        <article class="card">
          <div class="stat-label">Status DB</div>
          <div class="stat-value"><%= dbHealthy ? "Connected" : "Unavailable" %></div>
        </article>
        <article class="card">
          <div class="stat-label">Environment</div>
          <div class="stat-value"><%= environment %></div>
        </article>
        <article class="card">
          <div class="stat-label">Uptime</div>
          <div class="stat-value"><%= uptime %></div>
        </article>
        <article class="card">
          <div class="stat-label">Endpoint</div>
          <div class="stat-value"><%= totalEndpointCount %></div>
        </article>
      </section>

      <section class="stack">
        <article class="card">
          <div class="stat-label">Route Utama</div>
          <div class="list">
            <% quickLinks.forEach((item) => { %>
              <div class="list-item">
                <div>
                  <div class="badge"><%= item.method %></div>
                  <div style="margin-top:10px; font-weight: 800;"><%= item.path %></div>
                  <p style="margin-top:8px;"><%= item.summary %></p>
                </div>
                <div style="min-width: 110px; text-align: right; color: var(--muted); font-weight: 700;">
                  <%= item.auth %>
                </div>
              </div>
            <% }) %>
          </div>
        </article>

        <article class="card">
          <div class="stat-label">Informasi Server</div>
          <div class="list">
            <div class="list-item">
              <div>
                <div style="font-weight: 800;">Waktu server</div>
                <p style="margin-top:6px;"><%= now %></p>
              </div>
            </div>
            <div class="list-item">
              <div>
                <div style="font-weight: 800;">Uploads</div>
                <p style="margin-top:6px;">Disajikan dari <code>/uploads</code></p>
              </div>
            </div>
            <div class="list-item">
              <div>
                <div style="font-weight: 800;">Dokumentasi</div>
                <p style="margin-top:6px;">Semua endpoint tersedia di halaman <a href="/docs">/docs</a></p>
              </div>
            </div>
          </div>
        </article>
      </section>
    </div>
  </body>
</html>
